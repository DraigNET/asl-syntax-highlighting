{
  "name": "Quest ASLX",
  "scopeName": "text.xml.aslx",
  "fileTypes": ["aslx"],
  "firstLineMatch": "^\\s*(<!--.*?-->)?\\s*(<\\?xml\\b|<(asl|library)\\b)",
  "patterns": [
    { "include": "#scriptElements" },
    { "include": "#textElements" },
    { "include": "#questTags" },
    { "include": "text.xml" }
  ],
  "repository": {
    "scriptElements": {
      "patterns": [
        {
          "name": "meta.element.script.typed.aslx",
          "begin": "(<)([A-Za-z_][A-Za-z0-9_.-]*)(?=[^>]*\\btype\\s*=\\s*\"script\")([^>]*>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.xml" },
            "2": { "name": "entity.name.tag.script.aslx" },
            "3": {
              "name": "meta.tag.attributes.xml",
              "patterns": [
                { "include": "text.xml" }
              ]
            }
          },
          "end": "(</)(\\2)(\\s*>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.xml" },
            "2": { "name": "entity.name.tag.script.aslx" },
            "3": { "name": "punctuation.definition.tag.end.xml" }
          },
          "contentName": "source.asl",
          "patterns": [
            { "include": "#cdataAsl" },
            { "include": "text.xml" },
            { "include": "source.asl" }
          ]
        },
        {
          "name": "meta.element.script.aslx",
          "begin": "(<)(script|function|startscript|changedscript)\\b([^>]*>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.xml" },
            "2": { "name": "entity.name.tag.script.aslx" },
            "3": {
              "name": "meta.tag.attributes.xml",
              "patterns": [
                { "include": "text.xml" }
              ]
            }
          },
          "end": "(</)(\\2)(\\s*>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.xml" },
            "2": { "name": "entity.name.tag.script.aslx" },
            "3": { "name": "punctuation.definition.tag.end.xml" }
          },
          "contentName": "source.asl",
          "patterns": [
            { "include": "#cdataAsl" },
            { "include": "text.xml" },
            { "include": "source.asl" }
          ]
        }
      ]
    },
    "textElements": {
      "patterns": [
        {
          "name": "meta.element.text.aslx",
          "begin": "(<)(description|look|alias|prefix|suffix|alt|pattern|text|template|dynamictemplate|value|key|category|cover|author|version|firstpublished|gameid|location|pov|title|subtitle)\\b([^>]*>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.xml" },
            "2": { "name": "entity.name.tag.text.aslx" },
            "3": {
              "name": "meta.tag.attributes.xml",
              "patterns": [
                { "include": "text.xml" }
              ]
            }
          },
          "end": "(</)(\\2)(\\s*>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.xml" },
            "2": { "name": "entity.name.tag.text.aslx" },
            "3": { "name": "punctuation.definition.tag.end.xml" }
          },
          "contentName": "string.unquoted.text.aslx",
          "patterns": [
            { "include": "#cdataText" },
            { "include": "#textProcessor" },
            { "include": "text.xml" }
          ]
        }
      ]
    },
    "cdataAsl": {
      "name": "string.unquoted.cdata.aslx",
      "begin": "<!\\[CDATA\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.xml" }
      },
      "end": "\\]\\]>",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.xml" }
      },
      "patterns": [
        { "include": "source.asl" }
      ]
    },
    "cdataText": {
      "name": "string.unquoted.cdata.aslx",
      "begin": "<!\\[CDATA\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.xml" }
      },
      "end": "\\]\\]>",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.xml" }
      },
      "patterns": [
        { "include": "#textProcessor" },
        { "include": "text.xml" }
      ]
    },
    "textProcessor": {
      "patterns": [
        {
          "name": "meta.quest.text-processor.link.aslx",
          "match": "\\{(object|command|exit|page|rndalt|popup|here|nothere|select|img|counter):[^}]+\\}"
        },
        {
          "name": "meta.quest.text-processor.once.aslx",
          "begin": "\\{(once|notfirst|random):",
          "end": "\\}",
          "patterns": [
            { "include": "#textProcessor" }
          ]
        },
        {
          "name": "meta.quest.text-processor.conditional.aslx",
          "begin": "\\{(if not|if|else if|else|firsttime|either|eval|=):",
          "end": "\\}",
          "patterns": [
            { "include": "source.asl" }
          ]
        },
        {
          "name": "meta.quest.text-processor.format.aslx",
          "match": "\\{(b|i|u|s|colour|color|back):[^}]+\\}"
        },
        {
          "name": "meta.quest.text-processor.directive.aslx",
          "match": "\\{/?[A-Za-z][A-Za-z0-9_ -]*(?::[^}]*)?\\}"
        },
        {
          "name": "variable.other.text-processor.aslx",
          "match": "#[A-Za-z_][A-Za-z0-9_.\\[\\]]*#|%[A-Za-z_][A-Za-z0-9_.\\[\\]]*%"
        },
        {
          "name": "entity.name.function.text-processor.aslx",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*\\([^$]*\\)\\$"
        },
        {
          "name": "keyword.control.format.aslx",
          "match": "\\|(x?[biun]|c[brygl]|j[lcr]|s[0-9]{2}|[wc])\\b?"
        }
      ]
    },
    "questTags": {
      "patterns": [
        {
          "name": "entity.name.tag.quest.aslx",
          "match": "(?<=</?)(asl|library|include|template|dynamictemplate|verbtemplate|function|command|verb|type|game|object|exit|walkthrough|timer|turnscript|implied|delegate|javascript|editor|tab|control|resource|inherit|attr|item|statusattributes|displayverbs|inventoryverbs|take|drop|locked|scenery|feature_usegive|feature_transparent|feature_container|feature_switchable|feature_lightsource|showcompass|showplaces|showobjects|showscore|showinventory|start|pov|score|script|startscript|changedscript|speak|use|give|action|param|timeout|interval|enabled|finishaction|usedefaultprefix)(?=\\s|/?>)"
        },
        {
          "name": "entity.other.attribute-name.quest.aslx",
          "match": "\\b(name|type|parent|to|from|alias|pattern|unresolved|template|parameters|return|enabled|changed|inherit|src|language|version|author|category|displayverbs|inventoryverbs|ref|expression|element|property|object|timeout|interval|function|anonymous|value|default)\\b(?=\\s*=)"
        },
        {
          "name": "constant.language.boolean.aslx",
          "match": "(?<=>)(true|false)(?=</)"
        },
        {
          "name": "constant.numeric.aslx",
          "match": "(?<=>)\\d+(?:\\.\\d+)?(?=</)"
        }
      ]
    }
  }
}
