{
  "name": "Quest ASL",
  "scopeName": "source.asl",
  "fileTypes": ["asl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#textBlock" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#textProcessor" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#functionCalls" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.apostrophe.asl",
          "match": "^\\s*'.*$"
        }
      ]
    },
    "textBlock": {
      "name": "meta.block.text.asl",
      "begin": "\\b(define)\\s+(text)\\s+<([^>]+)>",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.asl" },
        "2": { "name": "storage.type.text.asl" },
        "3": { "name": "entity.name.section.asl" }
      },
      "end": "\\b(end)\\s+(define)\\b",
      "endCaptures": {
        "1": { "name": "keyword.declaration.asl" },
        "2": { "name": "keyword.declaration.asl" }
      },
      "patterns": [
        { "include": "#textProcessor" }
      ]
    },
    "preprocessor": {
      "name": "meta.preprocessor.asl",
      "match": "(?i)^\\s*(!include|!addto|!asl-version)\\b"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.asl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#escapeSequences" },
            { "include": "#textProcessor" }
          ]
        },
        {
          "name": "string.quoted.angle.asl",
          "begin": "<(?=\\S)",
          "end": ">",
          "patterns": [
            { "include": "#textProcessor" }
          ]
        }
      ]
    },
    "escapeSequences": {
      "name": "constant.character.escape.asl",
      "match": "\\\\."
    },
    "textProcessor": {
      "patterns": [
        {
          "name": "meta.quest.text-processor.link.asl",
          "match": "\\{(object|command|exit|page|rndalt|popup|here|nothere|select|img|counter):[^}]+\\}"
        },
        {
          "name": "meta.quest.text-processor.once.asl",
          "begin": "\\{(once|notfirst|random):",
          "end": "\\}",
          "patterns": [
            { "include": "#textProcessor" }
          ]
        },
        {
          "name": "meta.quest.text-processor.conditional.asl",
          "begin": "\\{(if not|if|else if|else|firsttime|either|eval|=):",
          "end": "\\}",
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#functionCalls" },
            { "include": "#variables" }
          ]
        },
        {
          "name": "meta.quest.text-processor.format.asl",
          "match": "\\{(b|i|u|s|colour|color|back):[^}]+\\}"
        },
        {
          "name": "meta.quest.text-processor.directive.asl",
          "match": "\\{/?[A-Za-z][A-Za-z0-9_ -]*(?::[^}]*)?\\}"
        },
        {
          "name": "variable.other.text-processor.asl",
          "match": "#[A-Za-z_][A-Za-z0-9_.\\[\\]]*#|%[A-Za-z_][A-Za-z0-9_.\\[\\]]*%"
        },
        {
          "name": "entity.name.function.text-processor.asl",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*\\([^$]*\\)\\$"
        },
        {
          "name": "keyword.control.format.asl",
          "match": "\\|(x?[biun]|c[brygl]|j[lcr]|s[0-9]{2}|[wc])\\b?"
        },
        {
          "name": "meta.embedded.expression.asl",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#functionCalls" },
            { "include": "#variables" }
          ]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.asl",
      "match": "\\b\\d+(?:\\.\\d+)?\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.asl",
          "match": "(?i)\\b(define|end|game|procedure|room|object|character|text|selection|timer|function|command|verb|type|script|synonyms)\\b"
        },
        {
          "name": "keyword.control.asl",
          "match": "(?i)\\b(if|then|else|elseif|switch|case|default|for|foreach|each|in|while|until|repeat|do|return|stop|and|or|not|is|has)\\b"
        },
        {
          "name": "support.function.builtin.asl",
          "match": "(?i)\\b(msg|msgto|OutputText|OutputTextNoBr|ask|ShowMenu|showmenu|ShowRoomDescription|ClearScreen|clear|SetFontName|SetFontSize|SetForegroundColour|SetBackgroundColour|SetLinkForegroundColour|SetPanelContents|ShowPicture|picture|playwav|playmidi|show|hide|goto|move|create|destroy|set|setvar|setstring|displaytext|displaymenu|debug|error|finish|pause|wait|JS|request|undo|invoke|rundelegate|do|MoveObject|MoveObjectHere|Clone|CloneObject|CloneObjectAndMove|CloneObjects|CreateBiExits|LockExit|UnlockExit|ExitIsAvailable|SetTimeout|SetTurnTimeout|SetTimerScript|DisableTimer|EnableTimer|SuppressTurnscripts|EnableTurnscripts|NewList|NewObjectList|NewStringList|ListAdd|ListRemove|ListCount|ListItem|IndexOf|Contains|ListContains|FilterByAttribute|ListCombine|StringListSort|ListExclude|ListSort|ListUnique|ObjectListSort|StringListItem|ObjectListItem|NewDictionary|DictionaryAdd|DictionaryRemove|DictionaryItem|DictionaryCount|DictionaryContains|DictionaryKeys|DictionaryValues|GetAttribute|HasAttribute|HasBoolean|HasString|HasInt|HasObject|HasScript|HasStringDictionary|GetBoolean|GetString|GetInt|GetObject|SetObjectFlagOn|SetObjectFlagOff|ToString|ToInt|ToDouble|TypeOf|Equal|IsDefined|IsNumeric|Abs|Sin|Cos|Tan|Sqrt|Max|Min|Round|Ceiling|Floor|GetRandomInt|GetRandomDouble|PickOneObject|PickOneString|PickOneUnique|DiceRoll|RandomChance|AllObjects|AllRooms|AllExits|ScopeInventory|ScopeReachable|ScopeVisible|ScopeReachableNotHeld|ScopeReachableForTake|Split|Join|Replace|LCase|UCase|LengthOf|Trim|StartsWith|EndsWith|Instr|InstrRev|Mid|Left|Right|CapFirst|AddToInventory|RemoveFromInventory|Got|IsAvailable|SwitchOn|SwitchOff|IncreaseScore|IncreaseHealth|IncreaseMoney|GetDisplayName|TryTake|TryDrop|Template|DynamicTemplate|Eval|GetFileData|RunDelegateFunction|RequestSave|RequestUndo)\\b"
        },
        {
          "name": "storage.type.asl",
          "match": "(?i)\\b(boolean|double|int|integer|object|string|script|list|dictionary|stringlist|objectlist|stringdictionary|objectdictionary|exit|command|function|delegate)\\b"
        },
        {
          "name": "constant.language.boolean.asl",
          "match": "(?i)\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.asl",
          "match": "(?i)\\b(game|player|this|parent|result)\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.asl",
      "match": "\\+|-|\\*|/|=|<>|<=|>=|<|>|\\b(and|or|not)\\b"
    },
    "functionCalls": {
      "name": "entity.name.function.asl",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.member.asl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
        },
        {
          "name": "variable.other.asl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
