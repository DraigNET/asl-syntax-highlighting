{
  "name": "Quest ASL",
  "scopeName": "source.asl",
  "fileTypes": ["asl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#textBlock" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#textProcessor" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#functionCalls" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.apostrophe.asl",
          "match": "^\\s*'.*$"
        }
      ]
    },
    "textBlock": {
      "name": "meta.block.text.asl",
      "begin": "\\b(define)\\s+(text)\\s+<([^>]+)>",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.asl" },
        "2": { "name": "storage.type.text.asl" },
        "3": { "name": "entity.name.section.asl" }
      },
      "end": "\\b(end)\\s+(define)\\b",
      "endCaptures": {
        "1": { "name": "keyword.declaration.asl" },
        "2": { "name": "keyword.declaration.asl" }
      },
      "patterns": [
        { "include": "#textProcessor" }
      ]
    },
    "preprocessor": {
      "name": "meta.preprocessor.asl",
      "match": "(?i)^\\s*(!include|!addto|!asl-version)\\b"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.asl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#escapeSequences" },
            { "include": "#textProcessor" }
          ]
        },
        {
          "name": "string.quoted.angle.asl",
          "begin": "<(?=\\S)",
          "end": ">",
          "patterns": [
            { "include": "#textProcessor" }
          ]
        }
      ]
    },
    "escapeSequences": {
      "name": "constant.character.escape.asl",
      "match": "\\\\."
    },
    "textProcessor": {
      "patterns": [
        {
          "name": "meta.quest.text-processor.link.asl",
          "match": "\\{(object|command|exit|page|once|notfirst|random|either):[^}]+\\}"
        },
        {
          "name": "meta.quest.text-processor.conditional.asl",
          "begin": "\\{(if|if not|else if|else|firsttime):",
          "end": "\\}",
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#functionCalls" },
            { "include": "#variables" }
          ]
        },
        {
          "name": "meta.quest.text-processor.directive.asl",
          "match": "\\{/?[A-Za-z][A-Za-z0-9_ -]*(?::[^}]*)?\\}"
        },
        {
          "name": "variable.other.text-processor.asl",
          "match": "#[A-Za-z_][A-Za-z0-9_.\\[\\]]*#|%[A-Za-z_][A-Za-z0-9_.\\[\\]]*%"
        },
        {
          "name": "entity.name.function.text-processor.asl",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*\\([^$]*\\)\\$"
        },
        {
          "name": "keyword.control.format.asl",
          "match": "\\|(x?[biun]|c[brygl]|j[lcr]|s[0-9]{2}|[wc])\\b?"
        },
        {
          "name": "meta.embedded.expression.asl",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#functionCalls" },
            { "include": "#variables" }
          ]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.asl",
      "match": "\\b\\d+(?:\\.\\d+)?\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.asl",
          "match": "(?i)\\b(define|end|game|procedure|room|object|character|text|selection|timer|function|command|verb|type|script|synonyms)\\b"
        },
        {
          "name": "keyword.control.asl",
          "match": "(?i)\\b(if|then|else|elseif|switch|case|default|for|foreach|each|in|while|until|repeat|do|return|stop|and|or|not|is|has)\\b"
        },
        {
          "name": "support.function.builtin.asl",
          "match": "(?i)\\b(msg|msgto|ask|show|hide|goto|move|create|destroy|set|setvar|setstring|displaytext|displaymenu|showmenu|ShowMenu|ShowRoomDescription|ClearScreen|clear|debug|error|finish|pause|wait|playwav|playmidi|JS|OutputText|Template|DynamicTemplate|GetBoolean|GetString|GetInt|GetObject|GetAttribute|SetObjectFlagOn|SetObjectFlagOff|SetTimeout|SetTurnTimeout|AddToInventory|RemoveFromInventory|MoveObject|MoveObjectHere|CloneObject|CloneObjectAndMove|ListCombine|NewStringList|NewObjectList|StringListItem|ObjectListItem|DictionaryAdd|DictionaryRemove|ListCount|StartsWith|EndsWith|Contains|LengthOf|LCase|UCase|CapFirst|ToString|ToInt|ToDouble|Split|Join|Instr|Replace|Mid|Left|Right|RandomChance|GetRandomInt|PickOneString|PickOneObject)\\b"
        },
        {
          "name": "storage.type.asl",
          "match": "(?i)\\b(boolean|double|int|integer|object|string|script|list|dictionary|stringlist|objectlist|exit|command|function|delegate)\\b"
        },
        {
          "name": "constant.language.boolean.asl",
          "match": "(?i)\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.asl",
          "match": "(?i)\\b(game|player|this|parent|result)\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.asl",
      "match": "\\+|-|\\*|/|=|<>|<=|>=|<|>|\\b(and|or|not)\\b"
    },
    "functionCalls": {
      "name": "entity.name.function.asl",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.member.asl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
        },
        {
          "name": "variable.other.asl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}

