{
  "name": "quest-asl",
  "displayName": "Quest ASL",
  "description": "Syntax highlighting for Quest ASL and ASLX files",
  "version": "1.0.9",
  "publisher": "DraigNETStudios",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xlithan/asl-syntax-highlighting"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "asl",
        "aliases": [
          "Quest ASL",
          "asl"
        ],
        "extensions": [
          ".asl"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "aslx",
        "aliases": [
          "Quest ASLX",
          "aslx"
        ],
        "extensions": [
          ".aslx"
        ],
        "configuration": "./language-configuration-aslx.json"
      }
    ],
    "grammars": [
      {
        "language": "asl",
        "scopeName": "source.asl",
        "path": "./syntaxes/asl.tmLanguage.json"
      },
      {
        "language": "aslx",
        "scopeName": "text.xml.aslx",
        "path": "./syntaxes/aslx.tmLanguage.json",
        "embeddedLanguages": {
          "source.asl": "asl",
          "text.xml": "xml"
        }
      }
    ],
    "snippets": [
      {
        "language": "asl",
        "path": "./snippets/asl.code-snippets"
      },
      {
        "language": "aslx",
        "path": "./snippets/aslx.code-snippets"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.9.1"
  }
}
