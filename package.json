{
  "name": "quest-asl",
  "displayName": "Quest ASLX",
  "description": "Syntax highlighting for Quest ASLX files",
  "version": "1.0.14",
  "publisher": "DraigNETStudios",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xlithan/asl-syntax-highlighting"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "aslx",
        "aliases": [
          "Quest ASLX",
          "aslx"
        ],
        "extensions": [
          ".aslx"
        ],
        "configuration": "./language-configuration-aslx.json"
      }
    ],
    "grammars": [
      {
        "scopeName": "source.asl",
        "path": "./syntaxes/asl.tmLanguage.json"
      },
      {
        "language": "aslx",
        "scopeName": "text.xml.aslx",
        "path": "./syntaxes/aslx.tmLanguage.json",
        "embeddedLanguages": {
          "text.xml": "xml"
        }
      }
    ],
    "snippets": [
      {
        "language": "aslx",
        "path": "./snippets/aslx.code-snippets"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "entity.name.tag.xml.quest.aslx",
            "settings": {
              "foreground": "#7EE787"
            }
          },
          {
            "scope": "entity.name.tag.xml.script.aslx",
            "settings": {
              "foreground": "#D2A8FF"
            }
          },
          {
            "scope": "entity.other.attribute-name.xml.quest.aslx",
            "settings": {
              "foreground": "#79C0FF"
            }
          },
          {
            "scope": "string.unquoted.element.xml.aslx",
            "settings": {
              "foreground": "#A5D6FF"
            }
          }
        ]
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.9.1"
  }
}
